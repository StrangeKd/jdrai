# Database
DATABASE_URL=postgresql://jdrai:jdrai@localhost:5432/jdrai

# Better Auth
BETTER_AUTH_SECRET=your-super-secret-key-min-32-chars-change-in-production
BETTER_AUTH_URL=http://localhost:3000

# API
API_PORT=3000
API_URL=http://localhost:3000

# Frontend
FRONTEND_URL=http://localhost:5173
# Web should call the API via same-origin `/api/*` (Vite proxy / reverse proxy in prod).
# Leave empty unless you intentionally switch to a cross-origin setup.
VITE_API_URL=

# LLM Providers
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-...
# Primary provider: "openai", "anthropic", or "openrouter"
LLM_PRIMARY_PROVIDER=openai
# Fallback provider order (comma-separated, allowed: openai,anthropic,openrouter; leave empty for no fallback)
LLM_FALLBACK_ORDER=anthropic
# Request timeout in milliseconds (default: 30s)
LLM_TIMEOUT_MS=30000
# Model names per provider
LLM_OPENAI_MODEL=gpt-4o
LLM_ANTHROPIC_MODEL=claude-sonnet-4-6
# OpenRouter model — supports any model on openrouter.ai (e.g. anthropic/claude-3.5-sonnet, google/gemini-pro)
LLM_OPENROUTER_MODEL=openai/gpt-4o

# Environment
NODE_ENV=development
