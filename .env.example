# Database
DATABASE_URL=postgresql://jdrai:jdrai@localhost:5432/jdrai

# Better Auth
BETTER_AUTH_SECRET=your-super-secret-key-min-32-chars-change-in-production
BETTER_AUTH_URL=http://localhost:3000

# API
API_PORT=3000
API_URL=http://localhost:3000

# Frontend
FRONTEND_URL=http://localhost:5173
# Web should call the API via same-origin `/api/*` (Vite proxy / reverse proxy in prod).
# Leave empty unless you intentionally switch to a cross-origin setup.
VITE_API_URL=

# LLM Providers
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-...
# Primary provider: "openai", "anthropic", or "openrouter"
LLM_PRIMARY_PROVIDER=openrouter
# Fallback provider order (comma-separated, used when primary fails)
LLM_FALLBACK_ORDER=openai,anthropic
# Request timeout in milliseconds (default: 30s)
LLM_TIMEOUT_MS=30000
# Ordered model list per provider (comma-separated — first model is tried first)
LLM_OPENAI_MODELS=gpt-4o
LLM_ANTHROPIC_MODELS=claude-sonnet-4-6
# Multiple models example: first free model is tried, fallback to second if it fails
LLM_OPENROUTER_MODELS=arcee/trinity-large-preview:free,step/step-3.5-flash:free

# Environment
NODE_ENV=development
