{
  "name": "@jdrai/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --exit-child src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:custom": "tsx src/db/migrate-custom.ts",
    "db:migrate:all": "pnpm db:migrate && pnpm db:migrate:custom",
    "db:seed": "tsx src/db/seeds/index.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@jdrai/shared": "workspace:*",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "pg": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.16.0",
    "drizzle-kit": "^0.31.9",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0"
  }
}
