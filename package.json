{
  "name": "jdrai",
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "pnpm --filter @jdrai/web dev",
    "dev:api": "pnpm --filter @jdrai/api dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:generate": "turbo run db:generate --filter=@jdrai/api",
    "db:migrate": "turbo run db:migrate --filter=@jdrai/api",
    "db:push": "turbo run db:push --filter=@jdrai/api",
    "db:studio": "turbo run db:studio --filter=@jdrai/api",
    "db:seed": "turbo run db:seed --filter=@jdrai/api",
    "db:reset": "turbo run db:reset --filter=@jdrai/api",
    "db:fresh": "pnpm --filter @jdrai/api db:reset && pnpm --filter @jdrai/api db:seed"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "prettier": "^3.8.1",
    "turbo": "^2.3.3",
    "typescript-eslint": "^8.56.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
